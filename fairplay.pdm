<a:Creator>Thiago</a:Creator>
<a:ModificationDate>1778449460</a:ModificationDate>
<a:Modifier>Thiago</a:Modifier>
<a:Comment>A seguradora estabelece um valor máximo que o tomador pode ter em apólices ativas (limite total).</a:Comment>
<a:DataType>decimal(18,2)</a:DataType>
<a:Length>18</a:Length>
<a:Precision>2</a:Precision>
<a:Column.Mandatory>1</a:Column.Mandatory>
</o:Column>
<o:Column Id="o1338">
