<a:Code>numApolice</a:Code>
<a:CreationDate>1770426580</a:CreationDate>
<a:Creator>Thiago</a:Creator>
<a:ModificationDate>1774484690</a:ModificationDate>
<a:Modifier>Thiago</a:Modifier>
<a:Comment>N mero identificador da ap lice:
            		Esse n mero deve ser formado por 24 d gitos, todos num ricos, conforme sequ ncia SSSSSAAAAFFFFRRRRNNNNNNN, onde:
            		SSSSS C digo da sociedade seguradora na SUSEP - 5 d gitos;
            		AAAA Ano de emiss o da ap lice - 4 d gitos;
            		FFFF Identificador da sucursal da emiss o da ap lice - 4 d gitos;
            		RRRR C digo do ramo da opera  o - 4 d gitos;
            		NNNNNNN N mero sequencial por ramo de opera  o - 7 d gitos</a:Comment>
<a:DataType>numeric(24,0)</a:DataType>
<a:Length>24</a:Length>
<a:Column.Mandatory>1</a:Column.Mandatory>
</o:Column>
