<a:Creator>Thiago</a:Creator>
<a:ModificationDate>1778449460</a:ModificationDate>
<a:Modifier>Thiago</a:Modifier>
<a:Comment>Indiga o tipo do grupo:
            G = Grupo Econômico, onde o controlador é responsável por 100% do limite de crédito do grupo (os demais participantes tem percentual de participação = 0%).
            C = Consórcio, onde o limite de crédito é composto pelo somatório dos percentuais de participação de cada consorciado (totalizando sempre 100%).</a:Comment>
<a:DataType>char(1)</a:DataType>
<a:Length>1</a:Length>
<a:Column.Mandatory>1</a:Column.Mandatory>
</o:Column>
